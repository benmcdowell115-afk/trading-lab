# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Whop ──────────────────────────────────────────────────────────────────────
# The public URL where users can buy — shown on the login screen
# e.g. https://whop.com/your-product-name/
VITE_WHOP_BUY_URL=https://whop.com/your-product/

# ── Server-side only (set in Netlify dashboard, NOT in .env) ──────────────────
# Whop API key — Whop dashboard → Developer → API Keys
# Add this in: Netlify → Site Settings → Environment Variables
# WHOP_API_KEY=your-whop-api-key
